{
  "identifier": "default",
  "description": "Castify default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/yt-dlp",
          "sidecar": true,
          "args": true
        },
        {
          "name": "binaries/ffmpeg",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "dialog:default",
    "notification:default",
    "store:default"
  ]
}
